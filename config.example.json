{
  "LOG": true,
  "LOG_LEVEL": "debug",
  "CLAUDE_PATH": "",
  "HOST": "127.0.0.1",
  "PORT": 3456,
  "APIKEY": "$CCR_API_KEY",
  "API_TIMEOUT_MS": 600000,
  "transformers": [],
  "Providers": [
    {
      "name": "cloudflare-minimax",
      "api_base_url": "http://127.0.0.1:8787/v1/messages",
      "api_key": "$CLOUDFLARE_API_KEY",
      "models": [
        "MiniMax-M2.7"
      ],
      "skipTransform": true,
      "transformer": {
        "use": ["outputconfig"]
      },
      "authType": "Bearer",
      "headers": {
        "cf-aig-authorization": "Bearer $CLOUDFLARE_API_KEY"
      }
    },
    {
      "name": "cloudflare-zai",
      "api_base_url": "http://127.0.0.1:8788/v1/messages",
      "api_key": "$CLOUDFLARE_API_KEY",
      "models": [
        "glm-5.1"
      ],
      "skipTransform": true,
      "authType": "Bearer",
      "headers": {
        "cf-aig-authorization": "Bearer $CLOUDFLARE_API_KEY"
      }
    }
  ],
  "StatusLine": {
    "enabled": true,
    "currentStyle": "powerline",
    "default": {
      "modules": [
        {
          "type": "workDir",
          "icon": "[",
          "text": "{{workDirName}}",
          "suffix": "]"
        },
        {
          "type": "gitBranch",
          "icon": "<",
          "text": "{{gitBranch}}",
          "suffix": ">"
        },
        {
          "type": "model",
          "icon": "(",
          "text": "{{model}}",
          "suffix": ")"
        },
        {
          "type": "usage",
          "icon": "in:",
          "text": "{{inputTokens}}"
        },
        {
          "type": "usage",
          "icon": "out:",
          "text": "{{outputTokens}}"
        }
      ]
    },
    "powerline": {
      "modules": [
        {
          "type": "workDir",
          "icon": "",
          "text": "{{workDirName}}",
          "color": "white",
          "background": "#141413"
        },
        {
          "type": "gitBranch",
          "icon": "",
          "text": "{{gitBranch}}",
          "color": "white",
          "background": "#3D2A1C"
        },
        {
          "type": "model",
          "icon": "",
          "text": "{{model}}",
          "color": "white",
          "background": "#6B4423"
        },
        {
          "type": "context",
          "icon": "",
          "text": "{{contextPercent}}%",
          "color": "white",
          "background": "#A35A30"
        },
        {
          "type": "usage",
          "icon": "↑",
          "text": "{{inputTokens}}",
          "color": "white",
          "background": "#C4603A"
        },
        {
          "type": "usage",
          "icon": "↓",
          "text": "{{outputTokens}}",
          "color": "black",
          "background": "#D97757"
        }
      ]
    }
  },
  "Router": {
    "default": "cloudflare-minimax,MiniMax-M2.7",
    "background": "cloudflare-minimax,MiniMax-M2.7",
    "think": "cloudflare-zai,glm-5.1",
    "longContext": "cloudflare-minimax,MiniMax-M2.7",
    "longContextThreshold": 60000
  },
  "fallback": {
    "think": [
      "cloudflare-zai,glm-5.1",
      "cloudflare-minimax,MiniMax-M2.7"
    ],
    "background": [
      "cloudflare-minimax,MiniMax-M2.7",
      "cloudflare-zai,glm-5.1"
    ],
    "longContext": [
      "cloudflare-minimax,MiniMax-M2.7",
      "cloudflare-zai,glm-5.1"
    ],
    "default": [
      "cloudflare-minimax,MiniMax-M2.7",
      "cloudflare-zai,glm-5.1"
    ]
  },
  "CUSTOM_ROUTER_PATH": ""
}
